<%= search_form_for @q, url: category_path(@category.alias), class: 'simple_form' do |f| %>
  <div class="form-group">
    <%= f.label t(:name, scope: 'activerecord.attributes.product') %>
    <%= f.search_field :name_cont,
                        class: 'form-control' %>
  </div>
  <div class="form-group">
    <%= f.label :price %>
    <%= f.search_field :price_gteq,
                        class: 'form-control', 
                        placeholder: t(:minimun) %>
    <%= f.search_field :price_lteq,
                        class: 'form-control', 
                        placeholder: t(:minimun) %>
  </div>

  <div class="form-group">
    <%= f.submit t(:search), class: "btn btn-primary" %>
    <%= link_to t(:clean), request.path, class: "btn btn-danger" %>
  </div>
<% end %>