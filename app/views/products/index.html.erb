<h1>Products</h1>

<div class="row products">
  <% @products.each do |product| %>
    <div class="card col-12 col-md-4 col-lg-3 p-0 mx-2" style="max-width: 260px;">
      <%= link_to product do %>
        <%= image_tag(product.photo, class: 'card-img-top', height: '200') %>
        <div class="card-body text-dark">
          <p class="card-text mb-0 font-weight-bold"><%= product.name %></p>
          <h4 class="card-title mb-0"><%= number_to_currency(product.price, unit: 'R$', separator: ',', delimiter: "") %></h4>
          <p class="card-text"><%= product.description %></p>
        </div>
      <% end %>
    </div>
    <%# <div style="height:100%; border:1px solid #c2c2c2;"></div> %>
  <% end %>
  </div>
</div>
