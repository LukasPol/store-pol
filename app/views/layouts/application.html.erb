<!DOCTYPE html>
<html>
  <head>
    <title>Store Pol</title>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= javascript_pack_tag 'application' %>
    <%= javascript_pack_tag 'scripts' %>
    <%= javascript_pack_tag 'styles' %>
  </head>

  <body data-flash-messages="<%= JSON.dump(flash.to_a) %>">
    <div class="container-fluid">
      <div class="row">
        <div class="col-12 p-5">
          <%= yield %>
        </div>
      </div>
    </div>
  </body>
</html>
