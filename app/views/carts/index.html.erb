<p id="notice"><%= notice %></p>

<h1><%= t(:cart, scope: 'activerecord.models')%></h1>







<table>
  <thead>
    <tr>
      <th><%= t(:image, scope: 'activerecord.attributes.product') %></th>
      <th><%= t(:name, scope: 'activerecord.attributes.product') %></th>
      <th><%= t(:price, scope: 'activerecord.attributes.product') %></th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @carts.each do |cart| %>
      <tr>
        <td><%= image_tag(cart.product.photo, height: '50') %></td>
        <td><%= cart.product.name %></td>
        <td><%= cart.product.price %></td>
      </tr>
    <% end %>
  </tbody>
</table>


<p>Total: <%= @value %></p>
<br>

<%= link_to t(:buy), order_path %>